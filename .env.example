# Copy this file to `.env` and fill in the values.

# PostgreSQL connection (Neon recommended for production).
# DATABASE_URL = pooled connection (app runtime). Uses the "-pooler" host.
# DIRECT_URL   = direct connection (migrations). Same host WITHOUT "-pooler".
# Local dev example: postgresql://<user>@localhost:5432/expense_tracker?schema=public
DATABASE_URL=""
DIRECT_URL=""

# Auth.js — generate with: openssl rand -base64 33
AUTH_SECRET=""
AUTH_TRUST_HOST=true

# Google OAuth (optional). Leave blank to use email/password only.
# Redirect URI to register: <your-url>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
