// Expense Tracker — Prisma schema
// Postgres + Auth.js adapter models + app models (Category, Transaction).

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled connection (app runtime)
  directUrl = env("DIRECT_URL") // direct connection (migrations)
}

enum TxType {
  INCOME
  EXPENSE
}

enum TxSource {
  MANUAL
  AUTO_SALARY
  RECURRING
}

enum Frequency {
  MONTHLY
  WEEKLY
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum MemberStatus {
  ACTIVE
  REMOVED
}

enum SplitType {
  EQUAL
  EXACT
  PERCENT
  SHARES
}

enum NoteRole {
  VIEWER
  EDITOR
}

enum NoteInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  passwordHash  String?
  image         String?
  emailVerified DateTime?

  // App settings
  currency        String @default("INR")
  monthlySalary   Float  @default(0)
  monthlyBudget   Float  @default(0)
  salaryCreditDay Int    @default(1) // day of month salary is credited

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  categories     Category[]
  transactions   Transaction[]
  recurringRules RecurringRule[]

  // Splitwise feature (all named relations — multiple FKs to User per model)
  friendshipsA      Friendship[]    @relation("FriendshipA")
  friendshipsB      Friendship[]    @relation("FriendshipB")
  sentFriendInvites FriendInvite[]  @relation("SentFriendInvites")
  recvFriendInvites FriendInvite[]  @relation("ReceivedFriendInvites")
  createdGroups     Group[]         @relation("CreatedGroups")
  groupMemberships  GroupMember[]   @relation("GroupMemberships")
  paidExpenses      SharedExpense[] @relation("PaidExpenses")
  createdExpenses   SharedExpense[] @relation("CreatedExpenses")
  expenseShares     ExpenseShare[]  @relation("ExpenseShares")
  settlementsFrom   Settlement[]    @relation("SettlementsFrom")
  settlementsTo     Settlement[]    @relation("SettlementsTo")

  // Notes feature
  notes             Note[]             @relation("NoteOwner")
  noteFolders       NoteFolder[]
  noteTagLabels     NoteTagLabel[]
  noteCollaborations NoteCollaborator[]
}

model Category {
  id            String  @id @default(cuid())
  userId        String
  name          String
  icon          String  @default("Tag")
  color         String  @default("#64748b")
  isDefault     Boolean @default(false)
  monthlyBudget Float   @default(0) // 0 = no per-category budget

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  recurringRules RecurringRule[]

  @@unique([userId, name])
  @@index([userId])
}

model Transaction {
  id         String   @id @default(cuid())
  userId     String
  amount     Float
  type       TxType   @default(EXPENSE)
  categoryId String?
  date       DateTime @default(now())
  note       String?
  source     TxSource @default(MANUAL)
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, type])
}

model RecurringRule {
  id               String    @id @default(cuid())
  userId           String
  amount           Float
  type             TxType    @default(EXPENSE)
  categoryId       String?
  note             String?
  frequency        Frequency @default(MONTHLY)
  dayOfMonth       Int       @default(1) // used when frequency = MONTHLY (1-28)
  weekday          Int       @default(1) // used when frequency = WEEKLY (0=Sun..6=Sat)
  active           Boolean   @default(true)
  startDate        DateTime  @default(now())
  endDate          DateTime?
  lastPostedPeriod String? // e.g. "2026-07" (monthly) or "2026-W27" (weekly)
  createdAt        DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// ---- Splitwise feature models ----
// Shared expenses are fully separate from the personal ledger (Transaction);
// nothing here ever writes a Transaction row.

// One row per pair of friends. Always stored with userAId < userBId (lexical)
// so the relationship is symmetric and deduped regardless of who invited whom.
model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())

  userA User @relation("FriendshipA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("FriendshipB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

// Friend request by email. inviteeId is back-filled on signup if the invitee
// did not yet have an account (see reconcileInvites).
model FriendInvite {
  id           String       @id @default(cuid())
  inviterId    String
  inviteeEmail String // lowercased
  inviteeId    String?
  status       InviteStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  respondedAt  DateTime?

  inviter User  @relation("SentFriendInvites", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee User? @relation("ReceivedFriendInvites", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@unique([inviterId, inviteeEmail])
  @@index([inviteeEmail])
  @@index([inviteeId, status])
}

model Group {
  id          String   @id @default(cuid())
  name        String
  createdById String
  createdAt   DateTime @default(now())

  createdBy   User            @relation("CreatedGroups", fields: [createdById], references: [id], onDelete: Cascade)
  members     GroupMember[]
  expenses    SharedExpense[]
  settlements Settlement[]

  @@index([createdById])
}

model GroupMember {
  id       String       @id @default(cuid())
  groupId  String
  userId   String? // null while an emailed invite is still pending
  email    String // lowercased invite email
  status   MemberStatus @default(ACTIVE)
  invite   InviteStatus @default(PENDING)
  isAdmin  Boolean      @default(false)
  joinedAt DateTime     @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User? @relation("GroupMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, email])
  @@index([groupId, status])
  @@index([userId, status])
}

model SharedExpense {
  id          String    @id @default(cuid())
  groupId     String? // set for group expenses; null for 1-on-1 friend expenses
  paidById    String
  amount      Float // total, in major units
  description String
  splitType   SplitType @default(EQUAL)
  date        DateTime  @default(now())
  createdById String
  createdAt   DateTime  @default(now())
  deletedAt   DateTime? // soft delete so balances stay reconstructable

  group     Group?         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy    User           @relation("PaidExpenses", fields: [paidById], references: [id], onDelete: Cascade)
  createdBy User           @relation("CreatedExpenses", fields: [createdById], references: [id], onDelete: Cascade)
  shares    ExpenseShare[]

  @@index([groupId, date])
  @@index([paidById])
}

model ExpenseShare {
  id         String @id @default(cuid())
  expenseId  String
  userId     String // participant who owes this portion
  owedAmount Float // computed share (sum of shares == expense.amount)
  shareValue Float? // raw exact/percent/weight as entered, for editing/re-derivation

  expense SharedExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User          @relation("ExpenseShares", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@index([userId])
}

model Settlement {
  id          String   @id @default(cuid())
  groupId     String? // set for in-group settlements; null for 1-on-1
  fromId      String // payer of the settlement (reduces what they owe)
  toId        String // receiver
  amount      Float
  note        String?
  date        DateTime @default(now())
  createdById String
  createdAt   DateTime @default(now())

  group Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  from  User   @relation("SettlementsFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to    User   @relation("SettlementsTo", fields: [toId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([fromId])
  @@index([toId])
}

// ---- Notes feature models ----
// Rich-text notes (TipTap JSON) with folders, tags, trash, and three sharing
// modes: public read-only link, email-invite collaborators, and friend shares.
// Fully separate from the personal ledger and Splitwise models.

model Note {
  id          String    @id @default(cuid())
  ownerId     String
  title       String    @default("")
  content     Json      @default("{}") // TipTap document JSON
  plainText   String    @default("") @db.Text // extracted text for search + list excerpt
  folderId    String?
  isPinned    Boolean   @default(false)
  isArchived  Boolean   @default(false)
  deletedAt   DateTime? // trash (soft delete)
  isPublic    Boolean   @default(false) // public-link toggle (revoke without losing token)
  publicToken String?   @unique // opaque token; rotate = regenerate
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner         User               @relation("NoteOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  folder        NoteFolder?        @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags          NoteTag[]
  collaborators NoteCollaborator[]

  @@index([ownerId, deletedAt, isArchived])
  @@index([folderId])
}

model NoteFolder {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  notes Note[]

  @@unique([ownerId, name])
}

model NoteTagLabel {
  id      String  @id @default(cuid())
  ownerId String
  name    String
  color   String?

  owner User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  notes NoteTag[]

  @@unique([ownerId, name])
}

// Join table: Note <-> NoteTagLabel
model NoteTag {
  noteId String
  tagId  String

  note Note         @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag  NoteTagLabel @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
  @@index([tagId])
}

// A share of a note with another person. email is always set (lowercased);
// userId is back-filled on signup by reconcileInvites when the invitee was
// emailed before having an account. Friend shares are created ACCEPTED.
model NoteCollaborator {
  id          String           @id @default(cuid())
  noteId      String
  email       String // lowercased target
  userId      String?
  role        NoteRole         @default(VIEWER)
  status      NoteInviteStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  respondedAt DateTime?

  note Note  @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noteId, email])
  @@index([userId, status])
  @@index([email, status])
}

// ---- Auth.js (NextAuth) adapter models ----

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
